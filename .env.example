# ══════════════════════════════════════════════════════════════════
# VeriCred Share — Environment Variables
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Application ──────────────────────────────────────────────────
APP_NAME=VeriCred Share
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vericred

# ── JWT Authentication ───────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-64
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Ed25519 Signing Key ─────────────────────────────────────────
# Generate with: python -c "import nacl.signing; print(nacl.signing.SigningKey.generate().encode().hex())"
# Leave empty to auto-generate (not recommended for production)
ED25519_PRIVATE_KEY_HEX=

# ── Issuer Identity ─────────────────────────────────────────────
ISSUER_DID=did:vericred:issuer:primary

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_VERIFY=20/minute
RATE_LIMIT_SHARE=30/minute
RATE_LIMIT_AUTH=10/minute

# ── Share Links ──────────────────────────────────────────────────
DEFAULT_SHARE_EXPIRY_HOURS=24
MAX_SHARE_EXPIRY_DAYS=30

# ── Frontend URL ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Frontend Environment ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
